# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Stripe ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Stripe CLI webhook secret (for local development: stripe listen --forward-to localhost:3000/api/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── NextAuth / Auth.js ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# ─── Okta OIDC ───────────────────────────────────────────────────────────────
# Create an OIDC Web App integration in your Okta developer dashboard.
# Callback URL: http://localhost:3000/api/auth/callback/okta
# Sign-out URL: http://localhost:3000
OKTA_CLIENT_ID=0oaXXXXXXXXXXXX
OKTA_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# e.g. https://dev-1234567.okta.com
OKTA_ISSUER=https://dev-XXXXXXX.okta.com
